# Open-Meteo needs no API key. GPT-5.6 extraction uses this backend-only value.
# For local development, copy this placeholder to ignored .env.local.
# Never expose it through a VITE_ variable or commit a real value.
OPENAI_API_KEY=

# Production-only settings. Values are operator supplied and validated at
# startup; the placeholders below are intentionally non-deployable.
HEATRELAY_HOST=0.0.0.0
HEATRELAY_PORT=8000
HEATRELAY_ALLOWED_HOSTS=
HEATRELAY_TRUSTED_PROXY_CIDRS=
HEATRELAY_MAX_REQUEST_BODY_BYTES=16384
HEATRELAY_RATE_LIMIT_REQUESTS=10
HEATRELAY_RATE_LIMIT_WINDOW_SECONDS=60
HEATRELAY_RATE_LIMIT_MAX_CLIENTS=4096
HEATRELAY_OPENAI_DAILY_BUDGET_USD=
HEATRELAY_OPENAI_PER_CALL_RESERVATION_USD=
HEATRELAY_HTTPS_EXPECTED=true
